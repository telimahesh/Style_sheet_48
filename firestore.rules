rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isSystemAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'telimahesh36@gmail.com' ||
        request.auth.uid == 'vBCUb3DI5vYHOOKFvSfHvv62UnE3'
      ) && (request.auth.token.email_verified == true || request.auth.uid == 'vBCUb3DI5vYHOOKFvSfHvv62UnE3');
    }
    
    function isStaff() {
      // Look up user role - note: get() in rules is expensive for lists, 
      // but fine for individual reads. For list security, we prefer checking token or data.
      return isSystemAdmin() || (isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'branch_manager', 'inventory_clerk']);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'whatsapp_no', 'role']) &&
             data.name is string && data.name.size() <= 100;
    }

    // --- Collection Matches ---

    // USERS
    match /users/{userId} {
      allow read, write: if true;
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /orders/{orderId}/items/{itemId} {
      allow read, write: if isSignedIn();
    }

    // OTHER COLLECTIONS
    match /branches/{branchId} { allow read: if true; allow write: if isSignedIn(); }
    match /inventory/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /pages/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /reviews/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // TEST COLLECTION
    match /test/{id} {
       allow read, write: if true;
    }

    // CATCH ALL DENY - Temporarily disabled for troubleshooting
    // match /{document=**} {
    //   allow read, write: if false;
    // }
  }
}
